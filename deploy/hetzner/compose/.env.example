# Schema for the production .env file (the keys, not the values). The actual
# /srv/virtua-fc/env/.env on the server is RENDERED BY CI on every deploy from
# GitHub Secrets and Variables — see .github/workflows/deploy.yml ("Render
# production .env" step). Editing the file on the server is pointless: the
# next deploy overwrites it.
#
# To change a value in production, set it in:
#   • Settings → Environments → production → Secrets   (sensitive: APP_KEY,
#     DB_PASSWORD, REDIS_PASSWORD, RESEND_API_KEY, NIGHTWATCH_TOKEN,
#     GRAFANA_ADMIN_PASSWORD, LOG_SLACK_WEBHOOK_URL, STORAGEBOX_USER/HOST,
#     HETZNER_HOST/USER/SSH_KEY)
#   • Settings → Environments → production → Variables (config: APP_DOMAIN,
#     ACME_EMAIL, MAIL_FROM_ADDRESS, GHCR_REPO, APP_LOCALE, APP_TIMEZONE,
#     LOG_LEVEL, BETA_MODE, DB_DATABASE, DB_USERNAME, MAIL_MAILER,
#     MAIL_FROM_NAME, TRUSTED_PROXIES, NIGHTWATCH_ENABLED, PULSE_ENABLED,
#     GRAFANA_ADMIN_USER, BACKUP_RETENTION_DAYS, STORAGEBOX_PATH)
# then re-run the workflow.
#
# Compose reads the rendered file via `docker compose --env-file
# /srv/virtua-fc/env/.env ...` (see deploy/hetzner/scripts/compose.sh).

# -------- Image --------
GHCR_REPO=pabloroman/virtua-fc
IMAGE_TAG=latest

# -------- Domain & TLS --------
APP_DOMAIN=virtuafc.example.com
APP_URL=https://virtuafc.example.com
ACME_EMAIL=ops@example.com

# -------- Laravel core --------
APP_ENV=production
APP_KEY=                           # generate once: docker run --rm <image> php artisan key:generate --show
APP_LOCALE=es
APP_TIMEZONE=UTC
LOG_LEVEL=info
BETA_MODE=false

# -------- Database --------
DB_DATABASE=virtua_fc
DB_USERNAME=virtua_fc
DB_PASSWORD=                       # strong random; rotate via deploy/hetzner/README.md

# -------- Redis --------
REDIS_PASSWORD=null                # 'null' literal disables auth; set a real password if exposing redis

# -------- Mail (Resend) --------
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=noreply@virtuafc.example.com
MAIL_FROM_NAME=VirtuaFC
RESEND_API_KEY=

# -------- Reverse proxy --------
TRUSTED_PROXIES=*

# -------- Monitoring --------
NIGHTWATCH_ENABLED=true
NIGHTWATCH_TOKEN=
PULSE_ENABLED=true

LOG_SLACK_WEBHOOK_URL=             # also reused by Grafana alerting

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=            # rotate after first login

# -------- Backups --------
BACKUP_RETENTION_DAYS=14
STORAGEBOX_USER=
STORAGEBOX_HOST=                   # e.g. uXXXXXX.your-storagebox.de
STORAGEBOX_PATH=/home/virtua-fc/backups
